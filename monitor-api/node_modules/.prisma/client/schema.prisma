// Monitor App — Prisma Schema
// Base de datos independiente de las instancias de Silver Star

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Un registro por cada cliente (Silver Star, Cliente 2, etc.)
model Tenant {
  id         String    @id @default(cuid())
  name       String // "Silver Star", "Cliente 2"
  apiKey     String    @unique // clave que el backend de Silver Star usa para autenticarse
  url        String // URL de la instancia para el uptime check
  lastSeenAt DateTime? // último ping recibido
  createdAt  DateTime  @default(now())

  events     Event[]
  uptimeLogs UptimeLog[]

  @@map("tenants")
}

// Todos los eventos de todas las instancias en una sola tabla
model Event {
  id        String   @id @default(cuid())
  tenantId  String
  eventType String // "ai.query.success", "ai.query.failed", "error.server", etc.
  payload   Json // datos específicos de cada evento
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, eventType])
  @@index([tenantId, createdAt])
  @@map("events")
}

// Historial de uptime — un registro por cada ping
model UptimeLog {
  id        String   @id @default(cuid())
  tenantId  String
  status    String // "up" | "down"
  latencyMs Int? // tiempo de respuesta del ping
  checkedAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, checkedAt])
  @@map("uptime_logs")
}
